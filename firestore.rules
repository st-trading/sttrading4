rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global safety net - default deny
    match /{document=**} {
      allow read, write: if false;
    }
    
    // Global helpers
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        request.auth.token.email == 'ehlolhan@gmail.com'
      );
    }
    
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    
    // Invariant validation for Inquiries
    function isValidInquiry(data) {
      return data.keys().hasAll(['companyName', 'name', 'email', 'productName', 'message', 'status', 'createdAt'])
        && data.companyName is string && data.companyName.size() >= 1 && data.companyName.size() <= 200
        && data.name is string && data.name.size() >= 1 && data.name.size() <= 100
        && data.email is string && data.email.size() >= 3 && data.email.size() <= 150
        && data.productName is string && data.productName.size() >= 1 && data.productName.size() <= 200
        && data.message is string && data.message.size() >= 1 && data.message.size() <= 2000
        && data.status is string && (data.status == 'pending' || data.status == 'reviewing' || data.status == 'completed')
        && data.createdAt is string && data.createdAt.size() <= 50
        && (!data.keys().hasAny(['userId']) || (data.userId is string && data.userId.size() <= 128))
        && (!data.keys().hasAny(['adminResponse']) || (data.adminResponse is string && data.adminResponse.size() <= 2000));
    }

    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /inquiries/{inquiryId} {
      allow get: if isAdmin() || (isSignedIn() && resource.data.keys().hasAll(['userId']) && resource.data.userId == request.auth.uid);
      allow list: if isAdmin() || (isSignedIn() && resource.data.keys().hasAll(['userId']) && resource.data.userId == request.auth.uid);
      
      allow create: if isValidId(inquiryId)
        && isValidInquiry(request.resource.data)
        && request.resource.data.status == 'pending'
        && (!request.resource.data.keys().hasAny(['userId']) || request.resource.data.userId == request.auth.uid)
        && (!request.resource.data.keys().hasAny(['adminResponse']));
        
      allow update: if isValidId(inquiryId)
        && isAdmin()
        && isValidInquiry(request.resource.data)
        // Immutable check: Ensure key client-provided fields are not modified
        && request.resource.data.companyName == resource.data.companyName
        && request.resource.data.name == resource.data.name
        && request.resource.data.email == resource.data.email
        && request.resource.data.productName == resource.data.productName
        && request.resource.data.message == resource.data.message
        && request.resource.data.createdAt == resource.data.createdAt
        && ((!resource.data.keys().hasAny(['userId']) && !request.resource.data.keys().hasAny(['userId'])) || (resource.data.keys().hasAll(['userId']) && request.resource.data.keys().hasAll(['userId']) && request.resource.data.userId == resource.data.userId));
        
      allow delete: if isAdmin();
    }
  }
}
